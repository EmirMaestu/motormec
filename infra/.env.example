# =============================================================
# MOTORMEC — Variables de Entorno Beta
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env.beta
#   2. Rellena TODOS los valores marcados con <CAMBIAR>
#   3. NUNCA subas .env.beta a git (ya está en .gitignore)
# =============================================================

# --- PostgreSQL --------------------------------------------------
# Contraseña para el usuario 'motormec' en la base de datos beta
# Genera una segura con: openssl rand -base64 32
POSTGRES_PASSWORD=<CAMBIAR_contraseña_segura_aquí>

# --- JWT Auth (se usa cuando la API esté activa) -----------------
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<CAMBIAR_jwt_secret_64_bytes_hex>
JWT_REFRESH_SECRET=<CAMBIAR_jwt_refresh_secret_64_bytes_hex>

# --- Convex (producción actual — solo lectura para el sync) ------
CONVEX_URL=https://charming-peacock-378.convex.cloud

# --- Tenant Beta -------------------------------------------------
# UUID del taller de pruebas en la nueva DB.
# Se genera automáticamente al correr init-beta.sh
BETA_TENANT_ID=<SE_GENERA_CON_init-beta.sh>

# --- Dominio -----------------------------------------------------
# Subdominio que apuntará al VPS para el entorno beta
BETA_DOMAIN=beta.tudominio.com
